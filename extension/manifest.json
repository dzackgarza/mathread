{
  "manifest_version": 3,
  "name": "MathRead PDF Viewer",
  "version": "0.1.0",
  "description": "Capture PDFs to the local MathRead service and read them in the MathRead reader.",
  "permissions": ["storage", "cookies"],
  "host_permissions": ["http://127.0.0.1:8765/*", "http://*/*", "https://*/*"],
  "background": {
    "service_worker": "mathread/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["mathread/link-origin.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["mathread/reader-swap.js"],
      "run_at": "document_start"
    }
  ],
  "action": {},
  "options_page": "mathread/options.html",
  "web_accessible_resources": [
    {
      "resources": ["poc/*"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
